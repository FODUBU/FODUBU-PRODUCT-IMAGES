import React, { useState, useEffect } from "react";
import { jsPDF } from "jspdf";

// Full Terms & Conditions content (simplified snippet, replace with full text)
const TERMS = {
  en: [
    { num: 1, title: "Introduction", body: `<p>Welcome to FODUBU® – Global Powering Trade, Agriculture, Industries, E-Commerce and growth with Pi.</p>` },
    { num: 2, title: "Definitions", body: `<p><strong>Platform:</strong> FODUBU® connects agriculture, industry, commerce, and e-commerce.</p>` },
    { num: 3, title: "Eligibility", body: `<p>Users must be 18+ and legally able to enter contracts.</p>` },
    { num: 4, title: "Account Registration", body: `<p>Accounts must contain accurate info and complete KYC.</p>` },
    { num: 5, title: "Payment & Pricing", body: `<p>Accepted payments: Pi Network. Fees & commissions apply.</p>` },
    { num: 6, title: "Consumer Rights & Delivery", body: `<p><strong>Returns:</strong> Within 7 days for damaged, defective, or unsent goods.</p>` },
    { num: 7, title: "B2B Terms", body: `<p>Direct between vendor & buyer. FODUBU® intervenes only if fraud occurs.</p>` },
    { num: 8, title: "Platform Rules", body: `<ul><li>No illegal or harmful content.</li><li>No abuse of payment systems.</li></ul>` },
    { num: 9, title: "Intellectual Property", body: `<p>All content is owned or licensed by FODUBU®.</p>` },
    { num: 10, title: "Liability Limits", body: `<ul><li>FODUBU® not liable for indirect losses or 3rd-party delays.</li></ul>` },
    { num: 11, title: "Dispute Resolution", body: `<p>Disputes resolved amicably under Burundian law; international disputes via arbitration.</p>` },
    { num: 12, title: "Amendments", body: `<p>FODUBU® may update these terms at any time. Updates published on the platform.</p>` },
    { num: 13, title: "Contact", body: `<p>Email: info@fodubu.com<br/>Phone: +257 76980980<br/>Office: Bujumbura, Ntahangwa, Burundi</p>` }
  ],
  fr: [/* French translation */],
  rn: [/* Kirundi translation */],
  zh: [/* Chinese */],
  sw: [/* Swahili */]
};

const LANG_SUBTITLES = {
  en: "Read carefully — these terms govern your use of FODUBU®",
  fr: "Lisez attentivement — ces conditions régissent votre utilisation de FODUBU®",
  rn: "Soma neza — aya mategeko agenga uburyo ukoresha FODUBU®",
  zh: "请仔细阅读 — 这些条款管理您对 FODUBU® 的使用",
  sw: "Soma kwa makini — masharti haya yanaongoza matumizi yako ya FODUBU®"
};

export default function Terms() {
  const [language, setLanguage] = useState("en");
  const [accepted, setAccepted] = useState(false);
  const [contact, setContact] = useState({ name: "", email: "", subject: "", message: "" });
  const acceptedKey = "fodubu_terms_accepted_v2";

  useEffect(() => {
    const storedAccepted = localStorage.getItem(acceptedKey) === "1";
    setAccepted(storedAccepted);

    const browserLang = (navigator.language || "en").slice(0,2);
    if(["en","fr","rn","zh","sw"].includes(browserLang)) setLanguage(browserLang);
  }, []);

  const toggleAccept = () => {
    if(accepted) {
      if(window.confirm("Unaccept terms? This will clear acceptance.")) {
        localStorage.removeItem(acceptedKey);
        setAccepted(false);
      }
    } else {
      localStorage.setItem(acceptedKey,"1");
      setAccepted(true);
      alert("You have accepted FODUBU® Terms & Conditions.");
    }
  };

  const handleDownloadPDF = async () => {
    const sections = TERMS[language] || TERMS.en;
    const doc = new jsPDF({ unit:"pt", format:"a4" });
    let html = `<div style="font-family:Arial,sans-serif;padding:20px;color:#111">`;
    html += `<h1>FODUBU® — Terms & Conditions</h1>`;
    html += `<h4>Language: ${language.toUpperCase()}</h4>`;
    sections.forEach(sec => {
      html += `<h2 style="margin-top:18px">${sec.num}. ${sec.title}</h2>`;
      html += `<div>${sec.body}</div>`;
    });
    html += `<hr><p>Contact: info@fodubu.com • +257 76980980 • Bujumbura, Ntahangwa, Burundi</p>`;
    html += `</div>`;

    try {
      await doc.html(html, { x:40, y:40, html2canvas:{ scale:0.95 }, callback: doc=>doc.save(`FODUBU_Terms_${language.toUpperCase()}.pdf`) });
    } catch(err) {
      let text = `FODUBU® — Terms & Conditions (${language.toUpperCase()})\n\n`;
      sections.forEach(sec => { text += `${sec.num}. ${sec.title}\n` + sec.body.replace(/<[^>]+>/g,'') + "\n\n"; });
      doc.text(text,40,40);
      doc.save(`FODUBU_Terms_${language.toUpperCase()}.pdf`);
    }
  };

  const handleContactChange = e => { const { id,value } = e.target; setContact(prev=>({...prev,[id]:value})); };
  const handleOpenMail = () => {
    const { name,email,subject,message } = contact;
    if(!name||!email||!message) return alert("Please fill name, email, message.");
    if(!accepted&&!window.confirm("You have not accepted Terms & Conditions. Continue?")) return;
    const body = `From: ${name}\nEmail: ${email}\n\n${message}\n---\nSent via FODUBU® website`;
    window.location.href = `mailto:info@fodubu.com?subject=${encodeURIComponent(subject||"Contact from FODUBU")}&body=${encodeURIComponent(body)}`;
  };
  const handleCopyMessage = async () => {
    const { name,email,subject,message } = contact;
    const text = `Subject: ${subject}\nFrom: ${name}\nEmail: ${email}\n\n${message}`;
    try{ await navigator.clipboard.writeText(text); alert("Message copied."); } catch { alert("Copy failed."); }
  };

  return (
    <div style={{ display:"grid", gridTemplateColumns:"1fr 360px", gap:"18px", padding:"18px" }}>
      {/* Main Terms */}
      <main style={{ padding:"20px", background:"#fff", borderRadius:"12px", overflowY:"auto", maxHeight:"80vh" }}>
        <div>
          <h2>Terms & Conditions — FODUBU®</h2>
          <div style={{ fontSize:"13px", color:"#64748b" }}>{LANG_SUBTITLES[language]}</div>
          <div style={{ margin:"12px 0" }}>
            <select value={language} onChange={e=>setLanguage(e.target.value)} style={{ marginBottom:"12px" }}>
              <option value="en">English</option>
              <option value="fr">Français</option>
              <option value="rn">Kirundi</option>
              <option value="zh">中文</option>
              <option value="sw">Kiswahili</option>
            </select>
            <button onClick={handleDownloadPDF} style={{ marginLeft:"8px" }}>⬇ Download PDF</button>
            <button onClick={toggleAccept} style={{ marginLeft:"8px" }}>{accepted?"Accepted ✓":"Accept"}</button>
          </div>
        </div>
        <ol>
          {TERMS[language]?.map(sec=>(
            <li key={sec.num}><a href={`#sec-${sec.num}`} onClick={e=>{e.preventDefault(); document.getElementById(`sec-${sec.num}`)?.scrollIntoView({behavior:"smooth"});}}>{sec.num}. {sec.title}</a></li>
          ))}
        </ol>
        {TERMS[language]?.map(sec=>(
          <section key={sec.num} id={`sec-${sec.num}`} style={{ marginTop:"20px" }}>
            <h3>{sec.num}. {sec.title}</h3>
            <div dangerouslySetInnerHTML={{ __html: sec.body }} />
          </section>
        ))}
      </main


