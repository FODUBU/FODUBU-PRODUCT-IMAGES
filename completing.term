// src/components/PrivacyPage.jsx
import React, { useState, useEffect } from 'react';

const STRINGS = {
  en: {
    title: 'FODUBU® — Privacy Policy',
    overview: 'Overview',
    contactTitle: 'Contact & Data Requests',
    submitRequest: 'Submit Request',
    cookieTitle: 'We use cookies',
    cookieText:
      'We use essential, analytics and marketing cookies to operate and improve the site. Manage preferences or accept to continue.',
  },
  rw: {
    title: "FODUBU® — Politiki y'Ubuzima bw'Umuntu",
    overview: "Ingingo y'ingaruka",
    contactTitle: 'Guhuza & Gusaba Data',
    submitRequest: 'Ohereza Itegeko',
    cookieTitle: 'Dukoresha cookies',
    cookieText:
      "Dukoresha cookies z'ingenzi, analytics na marketing kugirango urubuga rukore neza. Shyiraho uburyo cyangwa wemere.",
  },
};

export default function PrivacyPage() {
  const [lang, setLang] = useState('en');
  const [cookieConsent, setCookieConsent] = useState({ accepted: false, analytics: false, marketing: false });
  const [consentModalOpen, setConsentModalOpen] = useState(false);
  const [formMsg, setFormMsg] = useState('');

  // mimic user export
  const sampleUser = {
    name: 'Sample User',
    email: 'user@example.com',
    phone: '+257980980',
    addresses: { billing: 'Bujumbura, Ntahangwa' },
    transactions: [],
  };

  useEffect(() => {
    // Load saved consent from localStorage
    const saved = localStorage.getItem('fodubu_cookie_consent');
    if (saved) setCookieConsent(JSON.parse(saved));
  }, []);

  const logConsent = (action, details) => {
    const logs = JSON.parse(localStorage.getItem('fodubu_privacy_logs') || '[]');
    logs.push({ time: new Date().toISOString(), action, details });
    localStorage.setItem('fodubu_privacy_logs', JSON.stringify(logs));
    console.log('FODUBU privacy log:', action, details);
  };

  const saveConsent = (consent) => {
    setCookieConsent(consent);
    localStorage.setItem('fodubu_cookie_consent', JSON.stringify(consent));
    logConsent('consent_set', consent);
  };

  const downloadJSON = (filename, obj) => {
    const blob = new Blob([JSON.stringify(obj, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
  };

  const handlePrivacySubmit = (e) => {
    e.preventDefault();
    const type = e.target.requestType.value;
    const email = e.target.userEmail.value;
    const details = e.target.details.value;
    const payload = { type, email, details, requestedAt: new Date().toISOString() };
    setFormMsg('Request submitted. We will respond within 45 days.');
    logConsent('privacy_request_submitted', payload);
  };

  return (
    <main style={styles.wrap}>
      <header style={styles.header}>
        <div style={styles.brand}>
          <div style={styles.logo}>FD</div>
          <div>
            <h1>{STRINGS[lang].title}</h1>
            <p style={styles.lead}>
              Effective Date: <strong>07 September 2025</strong>
            </p>
            <div style={styles.metaPills}>
              <span style={styles.pill}>Multi-Sector Digital Trade Ecosystem</span>
              <span style={styles.pill}>Powered by Pi</span>
              <span style={styles.pill}>Bujumbura, Burundi</span>
            </div>
          </div>
        </div>
        <nav style={styles.controls}>
          <select value={lang} onChange={(e) => setLang(e.target.value)} style={styles.lang}>
            <option value="en">English</option>
            <option value="rw">Kinyarwanda</option>
          </select>
          <button style={styles.ghostBtn} onClick={() => document.getElementById('privacyRequestForm').scrollIntoView({ behavior: 'smooth' })}>
            Submit a Privacy Request
          </button>
          <button style={styles.btn} onClick={() => setConsentModalOpen(true)}>
            Cookie Settings
          </button>
        </nav>
      </header>

      <div style={styles.grid}>
        {/* Main content */}
        <section style={styles.card}>
          <div style={styles.sectionTitle}>
            <h2>{STRINGS[lang].overview}</h2>
            <span style={styles.muted}>Clear · Secure · Transparent</span>
          </div>
          <p style={styles.muted}>
            FODUBU® collects the minimum information necessary to provide marketplace services, process Pi payments, and keep your data secure. Below
            you’ll find details on what we collect, why, how long we keep it, and how to exercise your rights.
          </p>

          {/* Info sections */}
          <details open>
            <summary>1. Information We Collect</summary>
            <dl>
              <dt>Personal Data</dt>
              <dd>Name, email, phone number, billing & shipping addresses, and account credentials.</dd>
              <dt>Transaction Data</dt>
              <dd>Purchases, subscriptions, and Pi Network payment records (where applicable).</dd>
              <dt>Usage Data</dt>
              <dd>Login logs, preferences, and browsing patterns to improve the service.</dd>
              <dt>Device & Network Info</dt>
              <dd>IP address, browser type, device identifier and location (only with permission).</dd>
            </dl>
          </details>

          <details>
            <summary>2. How We Use Your Data</summary>
            <p style={styles.muted}>
              We use data to operate the platform, process payments, comply with legal obligations, and to enhance the user experience and marketing.
            </p>
          </details>

          <details>
            <summary>3. Your Rights</summary>
            <ul style={styles.muted}>
              <li>Access, correct, delete, or restrict your personal data.</li>
              <li>Request data portability (export your personal data).</li>
              <li>Withdraw consent at any time.</li>
              <li>Opt-out of sale or sharing of personal data (we do not sell personal data).</li>
            </ul>
          </details>

          <details>
            <summary>4. Data Retention & Security</summary>
            <p style={styles.muted}>
              We keep data only as long as needed for transactions, legal compliance, and support. Transactions are encrypted using Cloudflare SSL/TLS Full
              (Strict). Servers use access controls and monitoring.
            </p>
          </details>

          <details>
            <summary>5. Cookies & Tracking</summary>
            <p style={styles.muted}>
              We use essential cookies, analytics cookies, and marketing cookies. Manage preferences via the Cookie Settings dialog. Detailed cookie table
              is below.
            </p>
            <table style={{ width: '100%', borderCollapse: 'collapse' }}>
              <thead>
                <tr>
                  <th>Category</th>
                  <th>Purpose</th>
                  <th>Retention</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Essential</td>
                  <td>Site security, login, shopping cart</td>
                  <td>Session / 1 year</td>
                </tr>
                <tr>
                  <td>Analytics</td>
                  <td>Usage metrics and performance</td>
                  <td>13 months</td>
                </tr>
                <tr>
                  <td>Marketing</td>
                  <td>Personalized offers and ads</td>
                  <td>2 years</td>
                </tr>
              </tbody>
            </table>
          </details>

          <details>
            <summary>6. Children’s Privacy</summary>
            <p style={styles.muted}>FODUBU® is not for users under 18. We do not knowingly collect data from minors.</p>
          </details>

          <details>
            <summary>7. Governing Law & Disputes</summary>
            <p style={styles.muted}>This policy is governed by the laws of Burundi. Disputes will be addressed via Notarian Jurisdiction.</p>
          </details>

          <details>
            <summary>8. Changes to This Policy</summary>
            <p style={styles.muted}>We may update this Privacy Policy. Changes will be posted here and communicated when appropriate.</p>
          </details>

          {/* Contact & form */}
          <section>
            <h3>{STRINGS[lang].contactTitle}</h3>
            <p style={styles.mutedSmall}>
              To exercise your rights or submit a request, use the form or contact:
            </p>
            <p style={styles.mutedSmall}>
              Email: <a href="mailto:support@fodubu.com">support@fodubu.com</a> • Phone: <a href="tel:+257980980">+257 980980</a>
            </p>

            <form id="privacyRequestForm" onSubmit={handlePrivacySubmit}>
              <label>
                Request Type
                <select name="requestType" required>
                  <option value="access">Access my data</option>
                  <option value="portability">Data portability</option>
                  <option value="correction">Correct my data</option>
                  <option value="deletion">Delete my data</option>
                  <option value="optout">Opt-out / Do not sell</option>
                </select>
              </label>

              <label>
                Your email
                <input name="userEmail" type="email" placeholder="you@example.com" required />
              </label>

              <label>
                Additional details (optional)
                <textarea name="details" rows="4" placeholder="Any verification info or notes..." />
              </label>

              <div style={{ display: 'flex', gap: 8, alignItems: 'center', marginTop: 10 }}>
                <button style={styles.btn} type="submit">
                  Submit Request
                </button>
                <button
                  style={styles.ghostBtn}
                  type="button"
                  onClick={() => {
                    document.getElementById('privacyRequestForm').reset();
                    setFormMsg('');
                  }}
                >
                  Reset
                </button>
                <div style={styles.mutedSmall}>{formMsg}</div>
              </div>
            </form>
          </section>

          <footer style={styles.footer}>
            <p style={styles.mutedSmall}>
              Contact: support@fodubu.com • Phone: +257 980980 • Address: Bujumbura, Ntahangwa, Burundi
            </p>
          </footer>
        </section>

        {/* Sidebar */}
        <aside style={styles.sidebar}>
          <div style={styles.cardBox}>
            <h3>Quick actions</h3>
            <p style={styles.muted}>Export your data, request deletion, or manage cookie preferences.</p>
            <button style={styles.smallBtn} onClick={() => downloadJSON('fodubu-data.json', sampleUser)}>
              Export my data (JSON)
            </button>
            <button
              style={styles.smallGhostBtn}
              onClick={() => {
                const email = 'support@fodubu.com';
                const subject = encodeURIComponent('Data deletion request - FODUBU');
                const body = encodeURIComponent(
                  'Hello FODUBU team,\n\nI request deletion of my personal data associated with this account. Please advise next steps and any verification required.\n\nThank you.'
                );
                logConsent('deletion_initiated', { method: 'mailto' });
                window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
              }}
            >
              Request deletion
            </button>
          </div>

          <div style={styles.cardBox}>
            <h4>Cookie Settings</h4>
            <p style={styles.muted}>Toggle categories to customize tracking.</p>
            <label>
              <input type="checkbox" checked disabled /> Essential (required)
            </label>
            <label>
              <input
                type="checkbox"
                checked={cookieConsent.analytics}
                onChange={(e) => saveConsent({ ...cookieConsent, analytics: e.target.checked })}
              />{' '}
              Analytics
            </label>
            <label>
              <input
                type="checkbox"
                checked={cookieConsent.marketing}
                onChange={(e) => saveConsent({ ...cookieConsent, marketing: e.target.checked })}
              />{' '}
              Marketing
            </label>
  
